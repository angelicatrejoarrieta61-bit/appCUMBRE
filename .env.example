# ── WhatsApp Cloud API ─────────────────────────────
# Token: temporal (24h, panel API Setup) para pruebas;
# permanente (System User) para produccion.
WHATSAPP_TOKEN=
# Phone Number ID (NO es el numero de telefono): panel WhatsApp > API Setup
WHATSAPP_PHONE_ID=
# Cadena que TU inventas; se pega identica en Meta al configurar el webhook
WHATSAPP_VERIFY_TOKEN=cumbre2026_xK9mQ2

# ── Google Sheets ──────────────────────────────────
# client_email del JSON del service account
GOOGLE_SA_EMAIL=
# private_key del JSON (completa, con los \n tal cual vienen)
GOOGLE_SA_KEY=
# ID del spreadsheet: docs.google.com/spreadsheets/d/<ESTE_ID>/edit
SHEET_ID=

# ── Opcional ───────────────────────────────────────
# Telefono del staff que se muestra cuando no se encuentra al pasajero
STAFF_PHONE=+52 55 0000 0000
